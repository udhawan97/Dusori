{
  "name": "@udhawan97/dusori",
  "version": "0.4.0",
  "description": "Optional loopback-only companion for the Dusori local-first learning app.",
  "license": "Apache-2.0",
  "homepage": "https://udhawan97.github.io/Dusori/docs/getting-started/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/udhawan97/Dusori.git",
    "directory": "packages/companion"
  },
  "bugs": {
    "url": "https://github.com/udhawan97/Dusori/issues"
  },
  "keywords": [
    "local-first",
    "learning",
    "markdown",
    "obsidian",
    "pwa"
  ],
  "type": "module",
  "bin": {
    "dusori": "dist/cli.js"
  },
  "files": [
    "dist",
    "public",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/copy-app.mjs && tsup",
    "dev": "tsx src/cli.ts",
    "pack:check": "node scripts/verify-package.mjs",
    "prepack": "pnpm pack:check",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@fastify/cors": "11.3.0",
    "@fastify/static": "10.1.0",
    "@mozilla/readability": "0.6.0",
    "fastify": "5.10.0",
    "linkedom": "0.18.13",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@dusori/core": "workspace:*",
    "tsup": "8.5.1"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
