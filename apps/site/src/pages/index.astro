---
import '../styles/global.css';

import { appBasePath, docsBasePath, projectBasePath } from '../../../../config/site.mjs';

const appHref = `${appBasePath}/`;
const docsHref = `${docsBasePath}/`;
const releaseHref = 'https://github.com/udhawan97/Dusori/releases/tag/v0.4.0';
const githubHref = 'https://github.com/udhawan97/Dusori';
const licenseHref = 'https://github.com/udhawan97/Dusori/blob/main/LICENSE';
const graphShotHref = `${projectBasePath}/app-graph.png`;
const workspaceShotHref = `${projectBasePath}/app-workspace.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; base-uri 'self'; object-src 'none'; img-src 'self'; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    />
    <meta name="theme-color" content="#f7f1e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1b1715" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href={`${projectBasePath}/favicon.svg`} type="image/svg+xml" />
    <meta
      name="description"
      content="Dusori turns portable Markdown and JSON into a paced, local-first learning workspace."
    />
    <title>Dusori — learn deeply, keep the files</title>
  </head>
  <body>
    <svg class="page-defs" aria-hidden="true" focusable="false">
      <defs>
        <filter id="grainf">
          <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" stitchTiles="stitch"
          ></feTurbulence>
          <feColorMatrix type="saturate" values="0"></feColorMatrix>
        </filter>

        <g
          id="icon-wheel"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
        >
          <path d="M12 4 a8 8 0 1 1 -7.8 9.8"></path>
          <path d="M4.6 10.4 L4.2 13.8 L7.4 13"></path>
          <circle cx="12" cy="12" r="2"></circle>
        </g>
        <g
          id="icon-roadmap"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="4" y="4" width="6.5" height="6.5" rx="1"></rect>
          <path d="M5.8 7.2 l1.4 1.5 2.4 -2.9"></path>
          <path d="M14 7.2 H20"></path>
          <rect x="4" y="13.5" width="6.5" height="6.5" rx="1"></rect>
          <path d="M14 16.7 H20"></path>
        </g>
        <g
          id="icon-graph"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
        >
          <circle cx="6" cy="17" r="2.2"></circle>
          <circle cx="12" cy="6" r="2.2"></circle>
          <circle cx="18" cy="16" r="2.2"></circle>
          <path d="M7 15 L10.9 8 M13.2 7.9 L16.9 14.1 M8.2 17.4 L15.8 16.6"></path>
        </g>
        <g
          id="icon-blade"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 5 h8 v4 M4 5 v13 h5 M4 9 h4"></path>
          <rect x="12" y="7" width="8" height="12" rx="1"></rect>
          <path d="M3 21 L21 3"></path>
        </g>
        <g
          id="icon-source"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M6 3 h8 l4 4 v14 H6 z"></path>
          <path d="M14 3 v4 h4"></path>
          <path d="M9 12 h6 M9 16 h4"></path>
        </g>
        <g
          id="icon-browser"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
        >
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="M3 9 H21"></path>
          <path d="M6 7 h0.01 M8.6 7 h0.01"></path>
        </g>
        <g
          id="icon-folder"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M3 7 a1 1 0 0 1 1 -1 h5 l2 2 h9 a1 1 0 0 1 1 1 v8 a2 2 0 0 1 -2 2 H5 a2 2 0 0 1 -2 -2 z"
          ></path>
        </g>
        <g
          id="icon-terminal"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="3" y="4" width="18" height="16" rx="2"></rect>
          <path d="M7 9 l3 3 -3 3 M12.5 15 H17"></path>
        </g>
        <g
          id="icon-file"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M7 3 h7 l4 4 v14 H7 z"></path>
          <path d="M14 3 v4 h4"></path>
        </g>
        <g
          id="icon-json"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M9.5 4 c-2 0 -3 1 -3 3 v2 c0 1.6 -0.9 2.4 -2 3 c1.1 0.6 2 1.4 2 3 v2 c0 2 1 3 3 3"
          ></path>
          <path
            d="M14.5 4 c2 0 3 1 3 3 v2 c0 1.6 0.9 2.4 2 3 c-1.1 0.6 -2 1.4 -2 3 v2 c0 2 -1 3 -3 3"
          ></path>
        </g>

        <g id="scene-wheel">
          <circle
            cx="200"
            cy="200"
            r="168"
            style="fill: none; stroke: var(--sc-rule); stroke-width: 1; stroke-dasharray: 2 10;"
          ></circle>
          <circle
            cx="200"
            cy="200"
            r="118"
            pathLength="100"
            transform="rotate(-90 200 200)"
            style="fill: none; stroke: var(--sc-rule); stroke-width: 2; stroke-dasharray: 9.5 3;"
          ></circle>
          <circle
            class="wheel-arc"
            cx="200"
            cy="200"
            r="118"
            pathLength="100"
            transform="rotate(-90 200 200)"
            style="fill: none; stroke: var(--sc-gold); stroke-width: 7; stroke-dasharray: 34.5 65.5;"
          ></circle>
          <circle cx="200" cy="200" r="9" style="fill: var(--sc-gold);"></circle>
          <circle
            class="wheel-halo"
            cx="200"
            cy="200"
            r="20"
            style="fill: none; stroke: var(--sc-gold-soft); stroke-width: 1; stroke-dasharray: 3 5;"
          ></circle>
          <circle cx="200" cy="32" r="3" style="fill: var(--sc-line);"></circle>
          <circle cx="345" cy="283" r="3" style="fill: var(--sc-line);"></circle>
          <circle cx="55" cy="283" r="3" style="fill: var(--sc-line);"></circle>
        </g>

        <g id="scene-roadmap">
          <rect
            x="54"
            y="97"
            width="26"
            height="26"
            rx="3"
            style="fill: none; stroke: var(--sc-line); stroke-width: 1.5;"></rect>
          <path
            class="check check-1"
            d="M60 110 l7 8 l13 -15"
            pathLength="100"
            style="fill: none; stroke: var(--sc-red); stroke-width: 3.5; stroke-linecap: round; stroke-linejoin: round;"
          ></path>
          <path d="M100 104 H330" style="stroke: var(--sc-rule); stroke-width: 2;"></path>
          <path d="M100 118 H270" style="stroke: var(--sc-rule); stroke-width: 2; opacity: 0.55;"
          ></path>
          <rect
            x="54"
            y="182"
            width="26"
            height="26"
            rx="3"
            style="fill: none; stroke: var(--sc-line); stroke-width: 1.5;"></rect>
          <path
            class="check check-2"
            d="M60 195 l7 8 l13 -15"
            pathLength="100"
            style="fill: none; stroke: var(--sc-red); stroke-width: 3.5; stroke-linecap: round; stroke-linejoin: round;"
          ></path>
          <path d="M100 189 H322" style="stroke: var(--sc-rule); stroke-width: 2;"></path>
          <path d="M100 203 H252" style="stroke: var(--sc-rule); stroke-width: 2; opacity: 0.55;"
          ></path>
          <rect
            x="54"
            y="267"
            width="26"
            height="26"
            rx="3"
            style="fill: none; stroke: var(--sc-line); stroke-width: 1.5;"></rect>
          <path d="M100 274 H310" style="stroke: var(--sc-rule); stroke-width: 2;"></path>
          <path d="M100 288 H240" style="stroke: var(--sc-rule); stroke-width: 2; opacity: 0.55;"
          ></path>
          <circle
            class="next-ring"
            cx="340"
            cy="281"
            r="7"
            style="fill: none; stroke: var(--sc-gold); stroke-width: 2;"></circle>
        </g>

        <g id="scene-constellation">
          <path
            class="thread"
            d="M200 210 Q 150 150 118 108"
            style="fill: none; stroke: var(--sc-gold-soft); stroke-width: 1.3;"></path>
          <path
            class="thread"
            d="M200 210 Q 250 140 282 88"
            style="fill: none; stroke: var(--sc-gold-soft); stroke-width: 1.3;"></path>
          <path
            class="thread"
            d="M200 210 Q 270 220 322 232"
            style="fill: none; stroke: var(--sc-gold-soft); stroke-width: 1.3;"></path>
          <path
            class="thread"
            d="M200 210 Q 230 280 252 322"
            style="fill: none; stroke: var(--sc-gold-soft); stroke-width: 1.3;"></path>
          <path
            class="thread"
            d="M200 210 Q 148 254 108 282"
            style="fill: none; stroke: var(--sc-gold-soft); stroke-width: 1.3;"></path>
          <path
            class="thread"
            d="M200 210 Q 136 196 86 186"
            style="fill: none; stroke: var(--sc-gold-soft); stroke-width: 1.3;"></path>
          <path
            d="M118 108 Q 200 60 282 88"
            style="fill: none; stroke: var(--sc-gold-soft); stroke-width: 1.3; stroke-dasharray: 1 6; stroke-linecap: round;"
          ></path>
          <circle
            cx="200"
            cy="210"
            r="15"
            style="fill: var(--sc-node); stroke: var(--sc-gold); stroke-width: 2;"></circle>
          <circle
            class="hub-ring"
            cx="200"
            cy="210"
            r="26"
            style="fill: none; stroke: var(--sc-gold-soft); stroke-width: 1; stroke-dasharray: 3 6;"
          ></circle>
          <circle
            class="sat"
            cx="118"
            cy="108"
            r="8"
            style="fill: var(--sc-node); stroke: var(--sc-gold); stroke-width: 1.5;"></circle>
          <circle
            class="sat"
            cx="282"
            cy="88"
            r="7"
            style="fill: var(--sc-node); stroke: var(--sc-gold); stroke-width: 1.5;"></circle>
          <circle
            class="sat"
            cx="322"
            cy="232"
            r="9"
            style="fill: var(--sc-node); stroke: var(--sc-gold); stroke-width: 1.5;"></circle>
          <circle
            class="sat"
            cx="252"
            cy="322"
            r="7"
            style="fill: var(--sc-node); stroke: var(--sc-gold); stroke-width: 1.5;"></circle>
          <circle
            class="sat"
            cx="108"
            cy="282"
            r="8"
            style="fill: var(--sc-node); stroke: var(--sc-gold); stroke-width: 1.5;"></circle>
          <circle
            class="sat"
            cx="86"
            cy="186"
            r="6"
            style="fill: var(--sc-node); stroke: var(--sc-gold); stroke-width: 1.5;"></circle>
        </g>

        <g id="scene-blade">
          <g class="sheet-a">
            <rect
              x="64"
              y="96"
              width="148"
              height="198"
              style="fill: var(--sc-node); stroke: var(--sc-line); stroke-width: 1.5;"></rect>
            <path d="M84 136 H192" style="stroke: var(--sc-rule); stroke-width: 2;"></path>
            <path d="M84 166 H192" style="stroke: var(--sc-rule); stroke-width: 2;"></path>
            <path d="M84 196 H168" style="stroke: var(--sc-rule); stroke-width: 2;"></path>
          </g>
          <g class="sheet-b" transform="translate(212 118) rotate(1.5)">
            <rect
              width="148"
              height="198"
              style="fill: var(--sc-node); stroke: var(--sc-gold); stroke-width: 1.5;"></rect>
            <rect
              y="-16"
              width="64"
              height="16"
              style="fill: none; stroke: var(--sc-gold); stroke-width: 1.5;"></rect>
            <path d="M20 40 H128" style="stroke: var(--sc-rule); stroke-width: 2;"></path>
            <path d="M20 70 H128" style="stroke: var(--sc-rule); stroke-width: 2;"></path>
            <path d="M20 100 H104" style="stroke: var(--sc-rule); stroke-width: 2;"></path>
          </g>
          <path
            class="blade-line"
            d="M52 330 L348 62"
            pathLength="100"
            style="fill: none; stroke: var(--sc-red); stroke-width: 2.5; stroke-linecap: round;"
          ></path>
        </g>

        <g id="scene-sources">
          <path
            class="thread"
            d="M92 108 Q 200 120 268 178"
            style="fill: none; stroke: var(--sc-gold-soft); stroke-width: 1.3;"></path>
          <path
            class="consent-thread"
            d="M100 200 Q 190 200 264 200"
            style="fill: none; stroke: var(--sc-red); stroke-width: 1.3; stroke-dasharray: 5 5;"
          ></path>
          <path
            class="thread"
            d="M92 292 Q 200 282 268 224"
            style="fill: none; stroke: var(--sc-gold-soft); stroke-width: 1.3;"></path>
          <circle
            cx="84"
            cy="108"
            r="8"
            style="fill: var(--sc-node); stroke: var(--sc-gold); stroke-width: 1.5;"></circle>
          <circle
            cx="84"
            cy="200"
            r="8"
            style="fill: var(--sc-node); stroke: var(--sc-line); stroke-width: 1.5;"></circle>
          <circle
            class="consent-ring"
            cx="84"
            cy="200"
            r="16"
            style="fill: none; stroke: var(--sc-red); stroke-width: 1.5; stroke-dasharray: 4 4;"
          ></circle>
          <circle
            cx="84"
            cy="292"
            r="8"
            style="fill: var(--sc-node); stroke: var(--sc-line); stroke-width: 1.5;"></circle>
          <circle
            class="intake-arc"
            cx="312"
            cy="200"
            r="46"
            pathLength="100"
            transform="rotate(-90 312 200)"
            style="fill: none; stroke: var(--sc-gold); stroke-width: 5; stroke-dasharray: 62 38;"
          ></circle>
          <circle cx="312" cy="200" r="6" style="fill: var(--sc-gold);"></circle>
        </g>
      </defs>
    </svg>

    <header class="site-nav">
      <div class="nav-inner">
        <a class="wordmark" href={`${projectBasePath}/`} aria-label="Dusori home">
          <picture>
            <source
              srcset={`${projectBasePath}/brand/dusori-mark-reversed.svg`}
              media="(prefers-color-scheme: dark)"
            />
            <img src={`${projectBasePath}/brand/dusori-mark.svg`} alt="" width="28" height="28" />
          </picture>
          <span>Dusori</span>
        </a>
        <nav class="nav-links" aria-label="Site">
          <a href={docsHref}>Docs</a>
          <a class="nav-gh" href={githubHref}>GitHub</a>
          <a class="nav-cta" href={appHref}>Open app</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="hero-kicker">Free. Local-first. Useful without AI.</p>
          <h1 id="hero-title">Learn deeply. <span class="keyline">Keep the files.</span></h1>
          <p class="lede">
            Dusori turns plain Markdown and JSON into a paced learning workspace. It works offline,
            exports cleanly, and never develops mysterious opinions about who owns your notes.
          </p>
          <div class="hero-links">
            <a class="cta-primary" href={appHref}>Open Dusori →</a>
            <a class="cta-ghost" href={docsHref}>Read the docs →</a>
          </div>
        </div>

        <figure class="orbit-stage">
          <div class="bloom" aria-hidden="true"></div>
          <div class="grain" aria-hidden="true"></div>

          <div class="armature" aria-hidden="true">
            <div class="ring-tilt tilt-a">
              <div class="ring-spin spin-a">
                <div class="ring-face"></div>
                <i class="rn" style="--a: 10deg"></i>
                <i class="rn" style="--a: 150deg"></i>
                <i class="rn" style="--a: 260deg"></i>
              </div>
            </div>
            <div class="ring-tilt tilt-b">
              <div class="ring-spin spin-b">
                <div class="ring-face"></div>
                <i class="rn" style="--a: 70deg"></i>
                <i class="rn" style="--a: 230deg"></i>
              </div>
            </div>
            <div class="ring-tilt tilt-c">
              <div class="ring-spin spin-c">
                <div class="ring-face"></div>
                <i class="rn rn-big" style="--a: 330deg"></i>
                <i class="rn" style="--a: 120deg"></i>
                <i class="rn" style="--a: 200deg"></i>
              </div>
            </div>
          </div>

          <div class="drift-chips" aria-hidden="true">
            <span class="chip chip-1" style="--dz: 1.4; --dur: 9s"
              ><svg class="icon" viewBox="0 0 24 24"><use href="#icon-file"></use></svg
              >Overview.md</span
            >
            <span class="chip chip-2" style="--dz: 0.8; --dur: 7s"
              ><svg class="icon" viewBox="0 0 24 24"><use href="#icon-json"></use></svg
              >state.json</span
            >
            <span class="chip chip-3" style="--dz: 1.1; --dur: 11s"
              ><svg class="icon" viewBox="0 0 24 24"><use href="#icon-file"></use></svg
              >roadmap.md</span
            >
            <span class="chip chip-4" style="--dz: 0.6; --dur: 8s"
              ><svg class="icon" viewBox="0 0 24 24"><use href="#icon-json"></use></svg
              >Sources/manifest.json</span
            >
          </div>

          <picture class="hero-mark">
            <source
              srcset={`${projectBasePath}/brand/dusori-mark-reversed.svg`}
              media="(prefers-reduced-motion: reduce) and (prefers-color-scheme: dark)"
            />
            <source
              srcset={`${projectBasePath}/brand/dusori-mark.svg`}
              media="(prefers-reduced-motion: reduce)"
            />
            <source
              srcset={`${projectBasePath}/brand/dusori-mark-animated-reversed.svg`}
              media="(prefers-color-scheme: dark)"
            />
            <img
              src={`${projectBasePath}/brand/dusori-mark-animated.svg`}
              width="640"
              height="640"
              alt="Dusori ensō, rangoli, and katana mark"
              fetchpriority="high"
            />
          </picture>

          <figcaption class="stage-caption">
            <span class="release-flag">v0.4.0 · available now</span>
            <span>Japanese restraint · Indian geometry</span>
            <a href={releaseHref}>Read the release notes →</a>
          </figcaption>
        </figure>

        <ul class="truth-strip" role="list">
          <li>No account</li>
          <li>No telemetry</li>
          <li>No hosted backend</li>
          <li>Offline after first load</li>
          <li>Apache-2.0</li>
        </ul>
      </section>

      <section class="cinema" aria-label="What the workspace does">
        <div class="chapters">
          <article class="chapter" data-chapter="wheel">
            <span class="ch-icon" aria-hidden="true"
              ><svg class="icon" viewBox="0 0 24 24"><use href="#icon-wheel"></use></svg></span
            >
            <h2>Today decides what to review next.</h2>
            <p>
              Active topics come first, least recently updated first. The queue and the seven-day
              recap are derived from your roadmap, topic state, and dated update files — Dusori
              invents no deadlines and sends no reminders at 6 a.m.
            </p>
            <a class="chapter-link" href={`${docsHref}learning-loop/`}
              >How the learning loop works →</a
            >
            <svg class="chapter-art" viewBox="0 0 400 400" aria-hidden="true">
              <use href="#scene-wheel"></use>
            </svg>
          </article>

          <article class="chapter" data-chapter="roadmap">
            <span class="ch-icon" aria-hidden="true"
              ><svg class="icon" viewBox="0 0 24 24"><use href="#icon-roadmap"></use></svg></span
            >
            <h2>A roadmap that is just Markdown.</h2>
            <p>
              Checkboxes in <code>roadmap.md</code> are the plan. Check one in Dusori or in any other
              editor; topics move between active, paused, and complete without a project-management ceremony.
            </p>
            <a class="chapter-link" href={`${docsHref}getting-started/`}>Start your first topic →</a
            >
            <svg class="chapter-art" viewBox="0 0 400 400" aria-hidden="true">
              <use href="#scene-roadmap"></use>
            </svg>
          </article>

          <article class="chapter" data-chapter="constellation">
            <span class="ch-icon" aria-hidden="true"
              ><svg class="icon" viewBox="0 0 24 24"><use href="#icon-graph"></use></svg></span
            >
            <h2>Your notes, finally on speaking terms.</h2>
            <p>
              Every artifact, topic, and Obsidian-style [[wikilink]] becomes a constellation drawn
              in your browser. Select a node, open the file behind it. No graph database — backlinks
              are just resolved edges, reversed.
            </p>
            <a class="chapter-link" href={`${docsHref}knowledge-graph/`}
              >How the portable graph works →</a
            >
            <svg class="chapter-art" viewBox="0 0 400 400" aria-hidden="true">
              <use href="#scene-constellation"></use>
            </svg>
          </article>

          <article class="chapter" data-chapter="blade">
            <span class="ch-icon" aria-hidden="true"
              ><svg class="icon" viewBox="0 0 24 24"><use href="#icon-blade"></use></svg></span
            >
            <h2>Your editor gets the last word.</h2>
            <p>
              Dusori remembers the last content hash it saw. If a file changed elsewhere, that file
              stays untouched and the suggestion becomes a dated <code>.proposed-</code> version beside
              it. Acceptance is explicit, and recorded in <code>Updates/</code>.
            </p>
            <a class="chapter-link" href={`${docsHref}conflict-safety/`}
              >The conflict-safety contract →</a
            >
            <svg class="chapter-art" viewBox="0 0 400 400" aria-hidden="true">
              <use href="#scene-blade"></use>
            </svg>
          </article>

          <article class="chapter" data-chapter="sources">
            <span class="ch-icon" aria-hidden="true"
              ><svg class="icon" viewBox="0 0 24 24"><use href="#icon-source"></use></svg></span
            >
            <h2>Research that asks first.</h2>
            <p>
              Paste a source, add a file, or keep a URL reference with provenance. Microsoft Learn
              and Wikipedia suggestions are consent-gated; full-page extraction needs the optional
              local companion, and AI stays on the roadmap — not in your workspace.
            </p>
            <a class="chapter-link" href={`${docsHref}sources/`}>How sources and research work →</a>
            <svg class="chapter-art" viewBox="0 0 400 400" aria-hidden="true">
              <use href="#scene-sources"></use>
            </svg>
          </article>
        </div>

