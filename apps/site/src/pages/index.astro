<script>
  const nav = document.querySelector('.site-nav');
  if (nav) {
    const THRESHOLD = 80;
    let floating = false;
    let ticking = false;
    const update = () => {
      const next = window.scrollY > THRESHOLD;
      if (next !== floating) {
        floating = next;
        nav.classList.toggle('is-floating', floating);
      }
    };
    window.addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
      },
      { passive: true },
    );
    update();
  }

  const stage = document.querySelector<HTMLElement>('.scene-stage');
  const chapters = document.querySelectorAll<HTMLElement>('.chapter');
  if (stage && chapters.length > 0 && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && entry.target instanceof HTMLElement) {
            const scene = entry.target.dataset.chapter;
            if (scene) stage.dataset.scene = scene;
          }
        }
      },
      { rootMargin: '-45% 0px -45% 0px' },
    );
    for (const chapter of chapters) observer.observe(chapter);
  }

  // Pointer tilt on the hero observatory; fine pointers only, never under reduced motion.
  const hero = document.querySelector<HTMLElement>('.orbit-stage');
  const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (hero && finePointer.matches && !reducedMotion.matches) {
    hero.addEventListener('pointermove', (event) => {
      const rect = hero.getBoundingClientRect();
      const px = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
      const py = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
      hero.style.setProperty('--px', px.toFixed(3));
      hero.style.setProperty('--py', py.toFixed(3));
    });
    hero.addEventListener('pointerleave', () => {
      hero.style.setProperty('--px', '0');
      hero.style.setProperty('--py', '0');
    });
  }

  // Rest the observatory while it is off screen.
  if (hero && 'IntersectionObserver' in window) {
    const rest = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) hero.classList.toggle('is-resting', !entry.isIntersecting);
      },
      { threshold: 0.05 },
    );
    rest.observe(hero);
  }
</script>

