---
import '../styles/global.css';

import { appBasePath, docsBasePath, projectBasePath } from '../../../../config/site.mjs';

const appHref = `${appBasePath}/`;
const docsHref = `${docsBasePath}/`;
const screenshotHref = `${projectBasePath}/app-workspace.png`;
const releaseHref = 'https://github.com/udhawan97/Dusori/releases/tag/v0.3.0';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; base-uri 'self'; object-src 'none'; img-src 'self'; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    />
    <meta name="theme-color" content="#f7f1e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1b1715" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href={`${projectBasePath}/favicon.svg`} type="image/svg+xml" />
    <meta
      name="description"
      content="Dusori turns portable Markdown and JSON into a paced, local-first learning workspace."
    />
    <title>Dusori — learn deeply, keep the files</title>
  </head>
  <body>
    <header class="edge-nav">
      <a class="wordmark" href={`${projectBasePath}/`} aria-label="Dusori home">
        <picture>
          <source
            srcset={`${projectBasePath}/brand/dusori-mark-reversed.svg`}
            media="(prefers-color-scheme: dark)"
          />
          <img src={`${projectBasePath}/brand/dusori-mark.svg`} alt="" width="28" height="28" />
        </picture>
        <span>Dusori</span>
      </a>
      <a class="nav-action" href={appHref}>Open app</a>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="hero-kicker">A second brain with excellent boundaries.</p>
          <h1 id="hero-title">Learn deeply. Keep the files.</h1>
          <p class="lede">
            Dusori turns plain Markdown and JSON into a paced learning workspace. It works offline,
            exports cleanly, and never develops mysterious opinions about who owns your notes.
          </p>
          <div class="hero-links">
            <a href={appHref}>Open Dusori →</a>
            <a href={docsHref}>Read the docs →</a>
          </div>
        </div>
        <figure class="neural-stage">
          <div class="stage-heading" aria-hidden="true">
            <span>Dusori Ensō</span>
            <span>Japanese restraint · Indian geometry</span>
          </div>
          <picture class="hero-mark">
            <source
              srcset={`${projectBasePath}/brand/dusori-mark-reversed.svg`}
              media="(prefers-reduced-motion: reduce) and (prefers-color-scheme: dark)"
            />
            <source
              srcset={`${projectBasePath}/brand/dusori-mark.svg`}
              media="(prefers-reduced-motion: reduce)"
            />
            <source
              srcset={`${projectBasePath}/brand/dusori-mark-animated-reversed.svg`}
              media="(prefers-color-scheme: dark)"
            />
            <img
              src={`${projectBasePath}/brand/dusori-mark-animated.svg`}
              width="640"
              height="640"
              alt="Dusori ensō, rangoli, and katana mark"
              fetchpriority="high"
            />
          </picture>
          <figcaption class="stage-caption">
            <span>v0.3.0 · available now</span>
            <strong>Your notes stay ordinary files. A surprisingly radical idea.</strong>
            <a href={releaseHref}>Read the release notes →</a>
          </figcaption>
        </figure>
      </section>

      <section class="graph-proof" aria-labelledby="graph-proof-title">
        <div>
          <h2 id="graph-proof-title">Your notes, finally on speaking terms.</h2>
          <p>
            Dusori maps Markdown artifacts, topic structure, and Obsidian wikilinks directly in the
            browser. Select any artifact to open the file behind it. No graph database, sync
            account, or proprietary export ritual.
          </p>
          <a href={`${docsHref}knowledge-graph/`}>How the portable graph works →</a>
        </div>
        <figure class="graph-art" aria-label="A constellation of connected learning artifacts">
          <svg viewBox="0 0 620 420" aria-hidden="true">
            <circle class="orbit" cx="310" cy="210" r="154"></circle>
            <path
              d="M310 210 Q250 130 195 92 M310 210 Q386 140 455 98 M310 210 Q425 240 512 288 M310 210 Q274 320 224 350 M195 92 Q164 184 128 238 M455 98 Q490 168 512 288"
            ></path>
            <g class="home"
              ><circle cx="310" cy="210" r="18"></circle><circle cx="310" cy="210" r="28"
              ></circle></g
            >
            <g class="topic"
              ><circle cx="195" cy="92" r="13"></circle><circle cx="195" cy="92" r="20"></circle></g
            >
            <g
              ><circle cx="455" cy="98" r="8"></circle><circle cx="512" cy="288" r="8"
              ></circle><circle cx="224" cy="350" r="8"></circle><circle cx="128" cy="238" r="8"
              ></circle></g
            >
          </svg>
          <figcaption>Rangoli-like order for notes that remain ordinary Markdown.</figcaption>
        </figure>
      </section>

      <section class="product-view" aria-labelledby="product-title">
        <div class="section-heading">
          <h2 id="product-title">Less tab archaeology. More learning.</h2>
          <p>
            The workspace rail, reading canvas, and inspector below come from the real app. A
            fictional screenshot would be a strange way to sell local-first software.
          </p>
        </div>
        <figure>
          <img
            src={screenshotHref}
            width="1440"
            height="960"
            alt="Dusori Today view showing local topic progress, the next roadmap objective, and recent activity"
            fetchpriority="high"
          />
          <figcaption>
            Today is assembled from the topic’s roadmap, status, and dated update files.
          </figcaption>
        </figure>
      </section>

      <section class="contract" aria-labelledby="contract-title">
        <div>
          <h2 id="contract-title">Leave anytime. The files know the way out.</h2>
          <p>
            Each topic carries its overview, roadmap, preferences, notes, readable source files,
            machine state, and dated update history. Obsidian is welcome, never required.
          </p>
        </div>
        <pre
          aria-label="Dusori topic folder structure"><code>Topics/topic-name/
  Overview.md
  roadmap.md
  TUTOR.md
  state.json
  Notes/
  Updates/YYYY/MM/
  Sources/
    manifest.json
    items/hash-source.md</code></pre>
      </section>

      <section class="proof" aria-labelledby="proof-title">
        <div class="section-heading">
          <h2 id="proof-title">Your editor gets the last word.</h2>
          <p>Dusori does not start a custody battle with your Markdown.</p>
        </div>
        <div class="proof-flow">
          <div><span>1</span><p>Dusori remembers the last-seen content hash.</p></div>
          <div><span>2</span><p>If a file changed elsewhere, Dusori leaves it alone.</p></div>
          <div><span>3</span><p>The suggested version becomes a dated proposal beside it.</p></div>
        </div>
      </section>

      <section class="capabilities" aria-labelledby="capability-title">
        <div class="section-heading">
          <h2 id="capability-title">Useful everywhere. Extra local where browsers allow it.</h2>
        </div>
        <dl>
          <div>
            <dt>Modern browsers</dt><dd>
              Private workspace, interactive roadmap progress, Today summaries, pasted/file/URL
              sources, consent-gated research, curriculum previews, ZIP portability, offline reload.
            </dd>
          </div>
          <div>
            <dt>Chromium desktop</dt><dd>
              Everything above, plus direct access to one user-approved folder. One folder—not your
              entire digital attic.
            </dd>
          </div>
          <div>
            <dt>Local companion</dt><dd>
              Optional, session-scoped loopback service for exact-host-confirmed page extraction and
              ranked Microsoft Learn search. Ollama and unattended work remain future work.
            </dd>
          </div>
        </dl>
      </section>

      <section class="utility-index" aria-label="Project links">
        <a href={appHref}><span>Use</span>Open the browser app →</a>
        <a href={docsHref}><span>Understand</span>Read the file and browser contracts →</a>
        <a href="https://github.com/udhawan97/Dusori"
          ><span>Inspect</span>Review the source on GitHub →</a
        >
        <a href={releaseHref}><span>Release</span>What shipped in v0.3.0 →</a>
      </section>
    </main>

    <footer class="colophon">
      <p>
        Dusori is open-source software under the Apache License 2.0. No account, no telemetry, no
        hosted application backend—and no footnote quietly changing those facts. Version 0.3.0 adds
        an optional local companion for confirmed page extraction and ranked Microsoft Learn search;
        AI, general web search, and unattended scheduling remain future work.
      </p>
      <span>Built in public · 2026</span>
    </footer>
  </body>
</html>

<style>
  /* Hallmark · genre: atmospheric editorial · tone: dry, warm, quietly witty
   * anchor: vermilion action + marigold knowledge · structure: Marquee Hero with H2 split diptych
   * design-system: design.md · enrichment: supplied original Dusori Ensō at presentation scale
   * motion: finite chakra revolution + blade strike; exact supplied geometry settles intact
   * theme: custom supplied identity · nav: N9 · footer: Ft4 · designed-as-app
   * pre-emit critique: P5 H5 E5 S5 R5 V5 · contrast: pass (40–41) · slop: 58/58
   * responsive: pass (34, 49, 50–57)
   */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-width: 20rem;
    overflow-x: clip;
    background: var(--color-paper);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
  }

  a {
    color: inherit;
    white-space: nowrap;
  }

  a:active {
    text-decoration-thickness: 2px;
  }

  :focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 3px;
  }

  .edge-nav,
  main,
  .colophon {
    width: min(100%, 92rem);
    margin-inline: auto;
    padding-inline: var(--page-gutter);
  }

  .edge-nav {
    display: flex;
    min-height: 5rem;
    align-items: center;
    justify-content: space-between;
    border-block-end: var(--rule-hair) solid var(--color-rule);
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 600;
    text-decoration: none;
  }

  .wordmark img {
    flex: none;
    inline-size: 1.75rem;
    block-size: 1.75rem;
  }

  .wordmark picture {
    display: grid;
    place-items: center;
  }

  .nav-action {
    min-height: 2.75rem;
    padding: var(--space-xs) var(--space-md);
    border: var(--rule-hair) solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-accent-text);
    text-decoration: none;
    transition: background-color var(--dur-short) var(--ease-out);
  }

  .hero {
    display: grid;
    min-height: min(82dvh, 52rem);
    align-items: center;
    gap: var(--space-xl);
    padding-block: var(--space-2xl) var(--space-4xl);
    border-block-end: var(--rule-hair) solid var(--color-rule);
  }

  .hero-copy {
    min-width: 0;
  }

  h1,
  h2 {
    min-width: 0;
    margin: 0;
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 600;
    line-height: 1.08;
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 12ch;
    font-size: clamp(3rem, 3.75vw + 0.5rem, 4.75rem);
    letter-spacing: -0.02em;
  }

  h2 {
    max-width: 18ch;
    font-size: clamp(2rem, 3vw + 0.5rem, 3.75rem);
  }

  .hero-kicker {
    max-width: 36ch;
    margin: 0 0 var(--space-lg);
    color: var(--color-accent-text);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .lede {
    max-width: 54ch;
    margin-block-start: var(--space-lg);
    font-size: var(--text-md);
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-block-start: var(--space-lg);
  }

  .hero-links a {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    padding: var(--space-xs) var(--space-md);
    border: var(--rule-hair) solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-accent-text);
    text-decoration: none;
    transition: transform var(--dur-micro) var(--ease-out);
  }

  .hero-links a:first-child {
    border-color: var(--color-ink);
    background: var(--color-ink);
    color: var(--color-paper);
  }

  .hero-links a:active {
    transform: translateY(1px);
  }

  .neural-stage {
    position: relative;
    isolation: isolate;
    display: grid;
    min-width: 0;
    min-height: clamp(25rem, 72vw, 36rem);
    grid-template-rows: auto minmax(0, 1fr) auto;
    overflow: clip;
    padding: var(--space-md) 0 0 var(--space-lg);
    border-block-start: var(--rule-hair) solid var(--color-rule);
    background: var(--color-paper-2);
  }

  .neural-stage::before,
  .neural-stage::after {
    position: absolute;
    z-index: -1;
    background: var(--color-rule);
    content: '';
    pointer-events: none;
  }

  .neural-stage::before {
    inset: 50% 0 auto;
    block-size: var(--rule-hair);
  }

  .neural-stage::after {
    inset: 0 auto 0 50%;
    inline-size: var(--rule-hair);
  }

  .stage-heading {
    z-index: var(--z-base);
    display: grid;
    min-width: 0;
    gap: var(--space-2xs);
    padding-inline-end: var(--space-md);
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .stage-heading span:first-child {
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .hero-mark {
    z-index: var(--z-base);
    display: grid;
    width: min(100%, 34rem, 62dvh);
    place-self: center;
  }

  .hero-mark img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform var(--dur-long) var(--ease-out);
  }

  .stage-caption {
    z-index: var(--z-base);
    display: grid;
    gap: var(--space-2xs);
    margin: 0;
    padding: var(--space-md);
    border-block-start: var(--rule-hair) solid var(--color-rule);
    background: var(--color-paper);
  }

  .stage-caption span,
  figcaption,
  .colophon {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .stage-caption strong {
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: var(--text-sm);
  }

  .stage-caption a,
  .utility-index a {
    color: var(--color-accent-text);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.25em;
  }

  .product-view,
  .contract,
  .graph-proof,
  .proof,
  .capabilities,
  .utility-index {
    padding-block: var(--space-3xl);
    border-block-end: var(--rule-hair) solid var(--color-rule);
  }

  .section-heading {
    display: grid;
    gap: var(--space-md);
    margin-block-end: var(--space-xl);
  }

  .section-heading > p:last-child,
  .contract p {
    max-width: 58ch;
  }

  figure {
    margin: 0;
  }

  figure img {
    display: block;
    width: 100%;
    height: auto;
    border: var(--rule-hair) solid var(--color-rule);
  }

  figcaption {
    margin-block-start: var(--space-sm);
  }

  .contract {
    display: grid;
    gap: var(--space-xl);
  }

  .graph-proof {
    display: grid;
    align-items: center;
    gap: var(--space-xl);
  }

  .graph-proof > div > p:not(.kicker) {
    max-width: 56ch;
  }

  .graph-proof > div > a {
    display: inline-block;
    margin-block-start: var(--space-md);
    color: var(--color-accent-text);
  }

  .graph-art {
    padding: var(--space-md);
    border: var(--rule-hair) solid var(--color-rule);
    background: color-mix(in srgb, var(--color-marigold) 5%, var(--color-paper-2));
  }

  .graph-art svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .graph-art .orbit {
    fill: none;
    stroke: var(--color-rule);
    stroke-dasharray: 2 12;
  }

  .graph-art path {
    fill: none;
    stroke: color-mix(in srgb, var(--color-marigold) 72%, var(--color-rule));
    stroke-width: 1.25;
  }

  .graph-art circle:first-child {
    fill: var(--color-paper);
    stroke: var(--color-border);
  }

  .graph-art g circle:last-child {
    fill: none;
    stroke: var(--color-rule);
    stroke-dasharray: 3 5;
  }

  .graph-art .home circle:first-child {
    fill: var(--color-accent);
  }

  .graph-art .topic circle:first-child {
    fill: var(--color-marigold);
  }

  pre {
    min-width: 0;
    overflow: auto;
    margin: 0;
    padding: var(--space-lg);
    border-block: var(--rule-hair) solid var(--color-rule);
    background: var(--color-paper-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .proof-flow,
  .capabilities dl {
    display: grid;
    margin: 0;
    border-block-start: var(--rule-hair) solid var(--color-rule);
  }

  .proof-flow > div,
  .capabilities dl > div {
    display: grid;
    gap: var(--space-sm);
    padding-block: var(--space-lg);
    border-block-end: var(--rule-hair) solid var(--color-rule);
  }

  .proof-flow span {
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: var(--text-lg);
  }

  .proof-flow p,
  .capabilities dd {
    margin: 0;
  }

  .capabilities dt {
    font-weight: 700;
  }

  .capabilities dd {
    color: var(--color-muted);
  }

  .utility-index {
    display: grid;
  }

  .utility-index a {
    display: grid;
    min-height: 4.5rem;
    align-items: center;
    gap: var(--space-xs);
    padding-block: var(--space-md);
    border-block-end: var(--rule-hair) solid var(--color-rule);
  }

  .utility-index span {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
  }

  .colophon {
    display: grid;
    gap: var(--space-md);
    padding-block: var(--space-xl);
  }

  .colophon p {
    max-width: 72ch;
    margin: 0;
  }

  @media (hover: hover) and (pointer: fine) {
    .nav-action:hover {
      background: var(--color-paper-2);
    }

    .hero-links a:hover {
      transform: translateY(-1px);
    }

    .hero-links a:first-child:hover {
      background: var(--color-accent-text);
      color: var(--color-paper);
    }

    .hero-links a:last-child:hover {
      background: var(--color-paper-2);
      color: var(--color-ink);
    }

    .stage-caption a:hover,
    .utility-index a:hover {
      color: var(--color-ink);
      text-decoration-thickness: 2px;
    }

    .neural-stage:hover .hero-mark img {
      transform: translateY(calc(var(--space-2xs) * -1));
    }
  }

  @media (min-width: 40rem) {
    .stage-heading {
      display: flex;
      justify-content: space-between;
      gap: var(--space-sm);
    }

    .contract {
      grid-template-columns: minmax(0, 5fr) minmax(0, 4fr);
    }

    .graph-proof {
      grid-template-columns: minmax(0, 5fr) minmax(20rem, 4fr);
    }

    .proof-flow > div,
    .capabilities dl > div {
      grid-template-columns: minmax(8rem, 1fr) minmax(0, 2fr);
    }

    .utility-index a {
      grid-template-columns: 7rem minmax(0, 1fr);
    }

    .colophon {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }
  }

  @media (min-width: 64rem) {
    .hero {
      grid-template-columns: minmax(0, 9fr) minmax(30rem, 11fr);
      gap: var(--space-2xl);
    }

    .neural-stage {
      min-height: min(72dvh, 42rem);
      border-block-start: 0;
      border-inline-start: var(--rule-hair) solid var(--color-rule);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      transition-duration: 150ms !important;
    }

    .hero-mark img {
      transform: none !important;
      transition: none !important;
    }
  }
</style>
