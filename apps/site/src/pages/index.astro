---
import '../styles/global.css';

import { appBasePath, docsBasePath, projectBasePath } from '../../../../config/site.mjs';

const appHref = `${appBasePath}/`;
const docsHref = `${docsBasePath}/`;
const screenshotHref = `${projectBasePath}/app-workspace.png`;
const releaseHref = 'https://github.com/udhawan97/Dusori/releases/tag/v0.1.0';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; base-uri 'self'; object-src 'none'; img-src 'self'; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    />
    <meta name="theme-color" content="#f7f1e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1b1715" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href={`${projectBasePath}/favicon.svg`} type="image/svg+xml" />
    <meta
      name="description"
      content="Dusori turns portable Markdown and JSON into a paced, local-first learning workspace."
    />
    <title>Dusori — learn deeply, keep the files</title>
  </head>
  <body>
    <header class="edge-nav">
      <a class="wordmark" href={`${projectBasePath}/`} aria-label="Dusori home">
        <picture>
          <source
            srcset={`${projectBasePath}/brand/dusori-mark-reversed.svg`}
            media="(prefers-color-scheme: dark)"
          />
          <img src={`${projectBasePath}/brand/dusori-mark.svg`} alt="" width="28" height="28" />
        </picture>
        <span>Dusori</span>
      </a>
      <a class="nav-action" href={appHref}>Open app</a>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="hero-kicker">A second brain with excellent boundaries.</p>
          <h1 id="hero-title">Learn deeply. Keep the files.</h1>
          <p class="lede">
            Dusori turns plain Markdown and JSON into a paced learning workspace. It works offline,
            exports cleanly, and never develops mysterious opinions about who owns your notes.
          </p>
          <div class="hero-links">
            <a href={appHref}>Open Dusori →</a>
            <a href={docsHref}>Read the docs →</a>
          </div>
        </div>
        <figure class="neural-stage">
          <div class="stage-heading" aria-hidden="true">
            <span>Neural Ensō</span>
            <span>Japanese restraint · Indian geometry</span>
          </div>
          <svg
            class="neural-enso"
            viewBox="0 0 64 64"
            role="img"
            aria-labelledby="neural-enso-title neural-enso-description"
          >
            <title id="neural-enso-title">Dusori ensō, rangoli, and katana mark</title>
            <desc id="neural-enso-description">
              An ink ensō surrounds a connected neural pattern while a vermilion katana crosses the
              learning signal.
            </desc>

            <g class="enso-field">
              <path
                class="enso-brush"
                d="M55.77 26.51 C57.03 31.96 58.05 38.06 55.43 43.43 C52.81 48.8 48.57 53.28 43.11 55.83 C37.65 58.38 31.48 59.05 25.62 57.59 C19.76 56.13 14.65 52.61 11.03 47.8 C7.41 42.99 5.8 37.05 6.01 31.09 C6.22 25.13 8.71 19.57 12.58 15.12 C16.45 10.67 21.8 7.86 27.56 6.84 C33.32 5.82 38.85 8.28 43.67 10.95 C44.92 11.64 43.88 13.51 42.63 12.82 C38.24 10.38 33.06 11.05 28.45 11.86 C23.84 12.67 19.75 15.2 16.7 18.7 C13.65 22.2 12.18 26.72 12.02 31.3 C11.86 35.88 13.52 40.27 16.24 43.88 C18.96 47.49 22.89 49.95 27.25 51.04 C31.61 52.13 36.24 51.77 40.33 49.86 C44.42 47.95 47.92 44.84 49.92 40.74 C51.92 36.64 54.16 31.96 53.05 27.14 C52.63 25.33 55.35 24.7 55.77 26.51Z"
              ></path>

              <g class="neural-traces">
                <path d="M32 32 C28.4 30.8 25.6 26 21.4 23.3 C19.1 21.8 18.2 18.8 19.2 16.7"></path>
                <path d="M32 32 C34.4 28.4 38.1 26.5 42.5 22.2 C44.8 19.9 46.1 17.7 45.1 15.8"
                ></path>
                <path d="M32 32 C36.5 31.8 39.6 29.4 44.7 29.1 C47.2 29 49 27.8 50.2 25.8"></path>
                <path d="M32 32 C36.2 34 39.3 37.5 43.5 39.7 C46.2 41.1 47.5 43.5 47.4 46"></path>
                <path d="M32 32 C30.1 35.8 26.6 38.4 23 42.7 C21.2 44.8 18.8 45.7 16.7 45"></path>
                <path d="M32 32 C27.7 33.5 24.3 34 19.8 36.6 C17.5 37.9 15.1 37.7 13.4 36.2"></path>
              </g>

              <g class="neural-nodes">
                <circle class="neural-node node-one" cx="19.2" cy="16.7" r="0.72"></circle>
                <circle class="neural-node node-two" cx="45.1" cy="15.8" r="0.72"></circle>
                <circle class="neural-node node-three" cx="50.2" cy="25.8" r="0.72"></circle>
                <circle class="neural-node node-four" cx="47.4" cy="46" r="0.72"></circle>
                <circle class="neural-node node-five" cx="16.7" cy="45" r="0.72"></circle>
                <circle class="neural-node node-six" cx="13.4" cy="36.2" r="0.72"></circle>
              </g>

              <g class="rangoli-lines">
                <circle cx="32" cy="32" r="5.2" stroke-width="0.34"></circle>
                <circle cx="32" cy="32" r="1.9" stroke-width="0.3"></circle>
                <path
                  d="M32 26.8 L32 37.2 M26.8 32 L37.2 32 M28.32 28.32 L35.68 35.68 M35.68 28.32 L28.32 35.68"
                  stroke-width="0.3"></path>
                <path
                  d="M36.4 32 A2.2 2.2 0 0 1 35.11 35.11 A2.2 2.2 0 0 1 32 36.4 A2.2 2.2 0 0 1 28.89 35.11 A2.2 2.2 0 0 1 27.6 32 A2.2 2.2 0 0 1 28.89 28.89 A2.2 2.2 0 0 1 32 27.6 A2.2 2.2 0 0 1 35.11 28.89 A2.2 2.2 0 0 1 36.4 32"
                  stroke-width="0.28"></path>
                <path d="M32 29.6 L34.4 32 L32 34.4 L29.6 32 Z" stroke-width="0.26"></path>
                <circle
                  cx="32"
                  cy="32"
                  r="6.8"
                  stroke-width="0.22"
                  stroke-dasharray="1.1 2.3"
                  opacity="0.7"></circle>
                <circle cx="32" cy="32" r="7.6" stroke-width="0.16" opacity="0.4"></circle>
              </g>

              <g class="rangoli-points">
                <circle cx="27.83" cy="27.83" r="0.32"></circle>
                <circle cx="36.17" cy="36.17" r="0.32"></circle>
                <circle cx="36.17" cy="27.83" r="0.32"></circle>
                <circle cx="27.83" cy="36.17" r="0.32"></circle>
                <circle cx="37.4" cy="34.24" r="0.22"></circle>
                <circle cx="34.24" cy="37.4" r="0.22"></circle>
                <circle cx="29.76" cy="37.4" r="0.22"></circle>
                <circle cx="26.6" cy="34.24" r="0.22"></circle>
                <circle cx="26.6" cy="29.76" r="0.22"></circle>
                <circle cx="29.76" cy="26.6" r="0.22"></circle>
                <circle cx="34.24" cy="26.6" r="0.22"></circle>
                <circle cx="37.4" cy="29.76" r="0.22"></circle>
              </g>

              <g class="rangoli-diamonds">
                <path d="M32 24.75 L32.6 25.4 L32 26.05 L31.4 25.4 Z"></path>
                <path d="M39.25 32 L38.6 32.6 L37.95 32 L38.6 31.4 Z"></path>
                <path d="M32 39.25 L32.6 38.6 L32 37.95 L31.4 38.6 Z"></path>
                <path d="M24.75 32 L25.4 32.6 L26.05 32 L25.4 31.4 Z"></path>
              </g>
              <circle class="memory-node" cx="32" cy="32" r="0.85"></circle>
            </g>

            <g class="blade-settle">
              <g transform="translate(8.7 -6.8) rotate(142 32 32)">
                <path
                  class="blade-ink"
                  d="M7.1 30.9 L13.8 30.9 L13.8 33.1 L7.1 33.1 Q5.75 32 7.1 30.9 Z"></path>
                <path class="blade-paper" d="M9.3 31.1 L10.05 32 L9.3 32.9 L8.55 32 Z"></path>
                <path class="blade-paper" d="M11.7 31.1 L12.45 32 L11.7 32.9 L10.95 32 Z"></path>
                <ellipse class="blade-ink" cx="14.8" cy="32" rx="1.05" ry="3.35"></ellipse>
                <path class="blade-ink" d="M15.75 30.95 L17.2 30.95 L17.2 33.05 L15.75 33.05 Z"
                ></path>
                <path
                  class="blade-accent"
                  d="M17.2 30.95 L55.9 30.95 L58.2 31.3 L55.5 32.3 L17.2 33.05 Z"></path>
                <path
                  class="blade-highlight"
                  d="M18.3 31.55 L53.2 31.55"
                  stroke-width="0.5"
                  stroke-linecap="round"></path>
              </g>
            </g>
          </svg>
          <figcaption class="stage-caption">
            <span>v0.1.0 · available now</span>
            <strong>Your notes stay ordinary files. A surprisingly radical idea.</strong>
            <a href={releaseHref}>Read the release notes →</a>
          </figcaption>
        </figure>
      </section>

      <section class="graph-proof" aria-labelledby="graph-proof-title">
        <div>
          <h2 id="graph-proof-title">Your notes, finally on speaking terms.</h2>
          <p>
            Dusori maps Markdown artifacts, topic structure, and Obsidian wikilinks directly in the
            browser. Select any artifact to open the file behind it. No graph database, sync
            account, or proprietary export ritual.
          </p>
          <a href={`${docsHref}knowledge-graph/`}>How the portable graph works →</a>
        </div>
        <figure class="graph-art" aria-label="A constellation of connected learning artifacts">
          <svg viewBox="0 0 620 420" aria-hidden="true">
            <circle class="orbit" cx="310" cy="210" r="154"></circle>
            <path
              d="M310 210 Q250 130 195 92 M310 210 Q386 140 455 98 M310 210 Q425 240 512 288 M310 210 Q274 320 224 350 M195 92 Q164 184 128 238 M455 98 Q490 168 512 288"
            ></path>
            <g class="home"
              ><circle cx="310" cy="210" r="18"></circle><circle cx="310" cy="210" r="28"
              ></circle></g
            >
            <g class="topic"
              ><circle cx="195" cy="92" r="13"></circle><circle cx="195" cy="92" r="20"></circle></g
            >
            <g
              ><circle cx="455" cy="98" r="8"></circle><circle cx="512" cy="288" r="8"
              ></circle><circle cx="224" cy="350" r="8"></circle><circle cx="128" cy="238" r="8"
              ></circle></g
            >
          </svg>
          <figcaption>Rangoli-like order for notes that remain ordinary Markdown.</figcaption>
        </figure>
      </section>

      <section class="product-view" aria-labelledby="product-title">
        <div class="section-heading">
          <h2 id="product-title">Less tab archaeology. More learning.</h2>
          <p>
            The workspace rail, reading canvas, and inspector below come from the real app. A
            fictional screenshot would be a strange way to sell local-first software.
          </p>
        </div>
        <figure>
          <img
            src={screenshotHref}
            width="1440"
            height="960"
            alt="Dusori Today view showing local topic progress, the next roadmap objective, and recent activity"
            fetchpriority="high"
          />
          <figcaption>
            Today is assembled from the topic’s roadmap, status, and dated update files.
          </figcaption>
        </figure>
      </section>

      <section class="contract" aria-labelledby="contract-title">
        <div>
          <h2 id="contract-title">Leave anytime. The files know the way out.</h2>
          <p>
            Each topic carries its overview, roadmap, preferences, notes, readable source files,
            machine state, and dated update history. Obsidian is welcome, never required.
          </p>
        </div>
        <pre
          aria-label="Dusori topic folder structure"><code>Topics/topic-name/
  Overview.md
  roadmap.md
  TUTOR.md
  state.json
  Notes/
  Updates/YYYY/MM/
  Sources/
    manifest.json
    items/hash-source.md</code></pre>
      </section>

      <section class="proof" aria-labelledby="proof-title">
        <div class="section-heading">
          <h2 id="proof-title">Your editor gets the last word.</h2>
          <p>Dusori does not start a custody battle with your Markdown.</p>
        </div>
        <div class="proof-flow">
          <div><span>1</span><p>Dusori remembers the last-seen content hash.</p></div>
          <div><span>2</span><p>If a file changed elsewhere, Dusori leaves it alone.</p></div>
          <div><span>3</span><p>The suggested version becomes a dated proposal beside it.</p></div>
        </div>
      </section>

      <section class="capabilities" aria-labelledby="capability-title">
        <div class="section-heading">
          <h2 id="capability-title">Useful everywhere. Extra local where browsers allow it.</h2>
        </div>
        <dl>
          <div>
            <dt>Modern browsers</dt><dd>
              Private workspace, interactive roadmap progress, Today summaries, pasted/file/URL
              sources, curriculum previews, ZIP portability, offline reload.
            </dd>
          </div>
          <div>
            <dt>Chromium desktop</dt><dd>
              Everything above, plus direct access to one user-approved folder. One folder—not your
              entire digital attic.
            </dd>
          </div>
          <div>
            <dt>Local companion</dt><dd>
              Optional loopback service foundation. Ollama and fetching are future work; this page
              declines to time-travel.
            </dd>
          </div>
        </dl>
      </section>

      <section class="utility-index" aria-label="Project links">
        <a href={appHref}><span>Use</span>Open the browser app →</a>
        <a href={docsHref}><span>Understand</span>Read the file and browser contracts →</a>
        <a href="https://github.com/udhawan97/Dusori"
          ><span>Inspect</span>Review the source on GitHub →</a
        >
        <a href={releaseHref}><span>Release</span>What shipped in v0.1.0 →</a>
      </section>
    </main>

    <footer class="colophon">
      <p>
        Dusori is open-source software under the Apache License 2.0. No account, no telemetry, no
        hosted application backend—and no footnote quietly changing those facts. Version 0.1.0
        establishes the local-first workspace; AI, search, and unattended scheduling remain future
        work.
      </p>
      <span>Built in public · 2026</span>
    </footer>
  </body>
</html>

<style>
  /* Hallmark · genre: atmospheric editorial · tone: dry, warm, quietly witty
   * anchor: vermilion action + marigold knowledge · structure: Marquee Hero with H2 split diptych
   * design-system: design.md · enrichment: E5 dominant tier-B Neural Ensō · motion: settle + breath + signal
   * theme: custom supplied identity · nav: N9 · footer: Ft4 · designed-as-app
   * pre-emit critique: P5 H5 E5 S5 R5 V4 · contrast: pass · slop: pass
   */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-width: 20rem;
    overflow-x: clip;
    background: var(--color-paper);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
  }

  a {
    color: inherit;
    white-space: nowrap;
  }

  a:active {
    text-decoration-thickness: 2px;
  }

  :focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 3px;
  }

  .edge-nav,
  main,
  .colophon {
    width: min(100%, 92rem);
    margin-inline: auto;
    padding-inline: var(--page-gutter);
  }

  .edge-nav {
    display: flex;
    min-height: 5rem;
    align-items: center;
    justify-content: space-between;
    border-block-end: var(--rule-hair) solid var(--color-rule);
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 600;
    text-decoration: none;
  }

  .wordmark img {
    flex: none;
    inline-size: 1.75rem;
    block-size: 1.75rem;
  }

  .wordmark picture {
    display: grid;
    place-items: center;
  }

  .nav-action {
    min-height: 2.75rem;
    padding: var(--space-xs) var(--space-md);
    border: var(--rule-hair) solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-accent-text);
    text-decoration: none;
    transition: background-color var(--dur-short) var(--ease-out);
  }

  .hero {
    display: grid;
    min-height: min(82dvh, 52rem);
    align-items: center;
    gap: var(--space-xl);
    padding-block: var(--space-2xl) var(--space-4xl);
    border-block-end: var(--rule-hair) solid var(--color-rule);
  }

  .hero-copy {
    min-width: 0;
  }

  h1,
  h2 {
    min-width: 0;
    margin: 0;
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 600;
    line-height: 1.08;
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 12ch;
    font-size: clamp(3rem, 3.75vw + 0.5rem, 4.75rem);
    letter-spacing: -0.02em;
  }

  h2 {
    max-width: 18ch;
    font-size: clamp(2rem, 3vw + 0.5rem, 3.75rem);
  }

  .hero-kicker {
    max-width: 36ch;
    margin: 0 0 var(--space-lg);
    color: var(--color-accent-text);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .lede {
    max-width: 54ch;
    margin-block-start: var(--space-lg);
    font-size: var(--text-md);
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-block-start: var(--space-lg);
  }

  .hero-links a {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    padding: var(--space-xs) var(--space-md);
    border: var(--rule-hair) solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-accent-text);
    text-decoration: none;
    transition:
      color var(--dur-short) var(--ease-out),
      background-color var(--dur-short) var(--ease-out),
      transform var(--dur-micro) var(--ease-out);
  }

  .hero-links a:first-child {
    border-color: var(--color-ink);
    background: var(--color-ink);
    color: var(--color-paper);
  }

  .hero-links a:active {
    transform: translateY(1px);
  }

  .neural-stage {
    position: relative;
    isolation: isolate;
    display: grid;
    min-width: 0;
    min-height: clamp(25rem, 72vw, 36rem);
    grid-template-rows: auto minmax(0, 1fr) auto;
    overflow: clip;
    padding: var(--space-md) 0 0 var(--space-lg);
    border-block-start: var(--rule-hair) solid var(--color-rule);
    background: var(--color-paper-2);
  }

  .neural-stage::before,
  .neural-stage::after {
    position: absolute;
    z-index: -1;
    background: var(--color-rule);
    content: '';
    pointer-events: none;
  }

  .neural-stage::before {
    inset: 50% 0 auto;
    block-size: var(--rule-hair);
  }

  .neural-stage::after {
    inset: 0 auto 0 50%;
    inline-size: var(--rule-hair);
  }

  .stage-heading {
    z-index: var(--z-base);
    display: grid;
    min-width: 0;
    gap: var(--space-2xs);
    padding-inline-end: var(--space-md);
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .stage-heading span:first-child {
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .neural-enso {
    z-index: var(--z-base);
    display: block;
    width: min(100%, 34rem, 62dvh);
    height: auto;
    place-self: center;
    animation: mark-settle calc(var(--dur-long) * 1.5) var(--ease-out) both;
  }

  .enso-field {
    transform-origin: center;
    animation: enso-breathe calc(var(--dur-long) * 18) var(--ease-in-out) infinite;
  }

  .enso-brush,
  .blade-ink {
    fill: var(--color-ink);
  }

  .neural-traces,
  .rangoli-lines,
  .rangoli-diamonds {
    fill: none;
    stroke: var(--color-marigold);
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .neural-traces {
    stroke-width: 0.28;
  }

  .neural-traces path {
    opacity: 0.74;
    animation: trace-awaken calc(var(--dur-long) * 2) var(--ease-out) both;
  }

  .neural-traces path:nth-child(2) {
    animation-delay: var(--dur-micro);
  }

  .neural-traces path:nth-child(3) {
    animation-delay: calc(var(--dur-micro) * 2);
  }

  .neural-traces path:nth-child(4) {
    animation-delay: calc(var(--dur-micro) * 3);
  }

  .neural-traces path:nth-child(5) {
    animation-delay: calc(var(--dur-micro) * 4);
  }

  .neural-traces path:nth-child(6) {
    animation-delay: calc(var(--dur-micro) * 5);
  }

  .rangoli-lines {
    opacity: 0.88;
  }

  .rangoli-points,
  .memory-node,
  .neural-node {
    fill: var(--color-marigold);
  }

  .rangoli-diamonds {
    stroke-width: 0.26;
    opacity: 0.9;
  }

  .neural-node {
    transform-box: fill-box;
    transform-origin: center;
    animation: neural-signal calc(var(--dur-long) * 18) var(--ease-in-out) infinite;
  }

  .node-two {
    animation-delay: calc(var(--dur-long) * -3);
  }

  .node-three {
    animation-delay: calc(var(--dur-long) * -6);
  }

  .node-four {
    animation-delay: calc(var(--dur-long) * -9);
  }

  .node-five {
    animation-delay: calc(var(--dur-long) * -12);
  }

  .node-six {
    animation-delay: calc(var(--dur-long) * -15);
  }

  .blade-settle {
    transform-box: fill-box;
    transform-origin: center;
    animation: blade-settle calc(var(--dur-long) * 1.5) var(--ease-out) both;
    animation-delay: var(--dur-short);
  }

  .blade-paper {
    fill: var(--color-paper);
  }

  .blade-accent {
    fill: var(--color-accent);
  }

  .blade-highlight {
    fill: none;
    stroke: var(--color-paper);
  }

  .stage-caption {
    z-index: var(--z-base);
